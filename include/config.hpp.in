#pragma once

/*********************************************************************
 *  Configuration Header – Trace / Packet Limits
 *
 *  The following macros control the size and capacity of the trace
 *  collection system. They are intentionally kept in a separate header
 *  to make it easy to tune the system for different hardware or
 *  application requirements.
 *********************************************************************/

 /* --------------------------------------------------------------------
 *  Maximum number of traces that can be stored inside one packet.
 * -------------------------------------------------------------------- */
#define CONFIG_TRACE_MAX_PER_PACKET     @MAX_TRACE_PER_PACKET@

/* --------------------------------------------------------------------
 *  Maximum size of an individual trace payload (in bytes).
 * -------------------------------------------------------------------- */
#define CONFIG_TRACE_SIZE_MAX           @MAX_TRACE_SIZE@

/* --------------------------------------------------------------------
 *  Maximum number of packets that can exist simultaneously.
 * -------------------------------------------------------------------- */
#define CONFIG_PACKET_COUNT_MAX         @MAX_PACKETS@

/* --------------------------------------------------------------------------
 *  Derived constant
 * -------------------------------------------------------------------------- */

/* --------------------------------------------------------------------
 *  It is simply the product of the two limits above.  The value
 *  represents the maximum number of bytes that can be consumed by
 *  trace data in a single packet (excluding headers, timestamps,
 *  etc.).  This macro is handy when allocating buffers or performing
 *  bounds‑checks.
 * -------------------------------------------------------------------- */
#define TRACE_MAX_PAYLOAD_IN_BYTES   (CONFIG_TRACE_SIZE_MAX * CONFIG_TRACE_MAX_PER_PACKET)
